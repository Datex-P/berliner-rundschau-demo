# Berliner Rundschau — Environment Variables
# Copy to .env.local and fill in values

# CMS Adapter Selection
# Valid: contentful, storyblok, datocms, sanity, prismic, strapi, directus, hygraph, payload, wordpress, typo3, mock
# If not set, auto-detects based on which CMS env vars are present.
# CMS_ADAPTER=mock

# Additional image domains (comma-separated). Requires redeploy after change.
# CMS_IMAGE_DOMAINS=cdn.example.com,images.example.com

# Revalidation secret for CMS webhooks (POST /api/revalidate)
REVALIDATION_SECRET=your-secret-here

# Optional: API base URL override (defaults to localhost:3000 in dev)
# API_BASE_URL=https://berliner-rundschau.de

# --- Contentful ---
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=
# CONTENTFUL_ENVIRONMENT=master
# CONTENTFUL_ARTICLE_TYPE=article
# CONTENTFUL_FIELD_MAP={"headline":"title","teaser":"description"}

# --- Storyblok ---
# STORYBLOK_ACCESS_TOKEN=
# STORYBLOK_VERSION=published
# STORYBLOK_ARTICLE_TYPE=article
# STORYBLOK_FIELD_MAP=

# --- DatoCMS ---
# DATOCMS_API_TOKEN=
# DATOCMS_ENVIRONMENT=main
# DATOCMS_ARTICLE_MODEL=article
# DATOCMS_FIELD_MAP=

# --- Sanity ---
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_TOKEN=
# SANITY_ARTICLE_TYPE=article
# SANITY_FIELD_MAP=

# --- Prismic ---
# PRISMIC_REPOSITORY=
# PRISMIC_ACCESS_TOKEN=
# PRISMIC_ARTICLE_TYPE=article
# PRISMIC_FIELD_MAP=

# --- Strapi ---
# STRAPI_URL=http://localhost:1337
# STRAPI_API_TOKEN=
# STRAPI_VERSION=v5
# STRAPI_ARTICLE_COLLECTION=articles
# STRAPI_FIELD_MAP=

# --- Directus ---
# DIRECTUS_URL=http://localhost:8055
# DIRECTUS_STATIC_TOKEN=
# DIRECTUS_ARTICLE_COLLECTION=articles
# DIRECTUS_FIELD_MAP=

# --- Hygraph ---
# HYGRAPH_ENDPOINT=
# HYGRAPH_ACCESS_TOKEN=
# HYGRAPH_STAGE=PUBLISHED
# HYGRAPH_ARTICLE_MODEL=Article
# HYGRAPH_FIELD_MAP=

# --- Payload ---
# PAYLOAD_URL=http://localhost:3000
# PAYLOAD_API_KEY=
# PAYLOAD_ARTICLE_COLLECTION=articles
# PAYLOAD_FIELD_MAP=

# --- WordPress ---
# WORDPRESS_URL=https://example.com
# WORDPRESS_USERNAME=
# WORDPRESS_APP_PASSWORD=
# WORDPRESS_POST_TYPE=posts
# WORDPRESS_FIELD_MAP=

# --- TYPO3 ---
# Requires EXT:headless + EXT:news
# TYPO3_URL=https://cms.example.de
# TYPO3_API_TOKEN=
# TYPO3_ARTICLE_PAGE=/news
# TYPO3_CONTENT_PAGES=["/", "/news"]
# TYPO3_LANG_PREFIX=
# TYPO3_FIELD_MAP=
